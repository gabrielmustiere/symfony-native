<div {{ attributes }} class="px-4 pt-5">
    {# Barre de recherche + filtre #}
    <div class="space-y-3">
        <div class="relative">
            <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                <twig:ux:icon name="tabler:search" class="size-5"/>
            </span>
            <input type="search" inputmode="search" autocomplete="off"
                   data-model="debounce(300)|query"
                   placeholder="Rechercher une opération…"
                   class="block w-full rounded-xl border border-slate-200 bg-white py-2.5 pl-10 pr-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-[#16386b] focus:ring-2 focus:ring-[#16386b]/20 focus:outline-none dark:border-slate-700 dark:bg-slate-900 dark:text-white"/>
            {% if query is not empty %}
                <span data-loading class="absolute inset-y-0 right-3 flex items-center text-slate-400">
                    <twig:ux:icon name="tabler:loader-2" class="size-4 animate-spin"/>
                </span>
            {% endif %}
        </div>

        <div class="relative">
            <select data-model="category"
                    class="block w-full appearance-none rounded-xl border border-slate-200 bg-white py-2.5 pl-3 pr-9 text-sm text-slate-700 focus:border-[#16386b] focus:ring-2 focus:ring-[#16386b]/20 focus:outline-none dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                <option value="">Toutes les catégories</option>
                {% for case in this.categories %}
                    <option value="{{ case.value }}">{{ case.label }}</option>
                {% endfor %}
            </select>
            <span class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400">
                <twig:ux:icon name="tabler:chevron-down" class="size-4"/>
            </span>
        </div>
    </div>

    {# Résumé des résultats #}
    <div class="mt-4 flex items-baseline justify-between px-1">
        <span class="text-sm font-medium text-slate-500">
            {{ this.resultCount }} opération{{ this.resultCount > 1 ? 's' }}
        </span>
        <span class="font-display text-sm tabular-nums {{ this.resultSumCents >= 0 ? 'text-emerald-600 dark:text-emerald-400' : 'text-slate-700 dark:text-slate-200' }}">
            {{ this.resultSumCents|money(true) }}
        </span>
    </div>

    {# Résultats groupés par jour #}
    {% for group in this.groups %}
        <h2 class="mb-2 mt-4 px-1 font-display text-xs font-semibold uppercase tracking-wider text-slate-400">
            {{ group.date|day_label }}
        </h2>
        <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800">
            {% for tx in group.items %}
                {% include 'bank/_transaction.html.twig' with { tx: tx, divider: not loop.last } %}
            {% endfor %}
        </div>
    {% else %}
        <div class="mt-8 flex flex-col items-center gap-2 text-center text-slate-400">
            <twig:ux:icon name="tabler:search-off" class="size-8"/>
            <p class="text-sm">Aucune opération ne correspond à votre recherche.</p>
        </div>
    {% endfor %}

    {# Pagination #}
    {% if this.hasMore %}
        <button type="button" data-action="live#action" data-live-action-param="more"
                class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-white px-4 py-3 text-sm font-semibold text-[#0a2540] ring-1 ring-slate-200 transition hover:bg-slate-50 active:scale-[.99] dark:bg-slate-900 dark:text-white dark:ring-slate-700">
            <twig:ux:icon name="tabler:chevron-down" class="size-4"/>
            Afficher plus
        </button>
    {% endif %}
</div>
