{% set provided = form.documentProvided.vars.checked %}
<div class="space-y-5" data-test="step3">
    <header>
        <h1 class="font-display text-xl font-bold tracking-tight text-slate-900 dark:text-white">Pièce d'identité</h1>
        <p class="mt-1 text-sm text-slate-500">Déposez votre carte d'identité ou votre passeport pour vérification.</p>
    </header>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
        {% if provided %}
            {# État terminé #}
            <div id="onboarding-doc-verified" class="flex flex-col items-center gap-3 px-6 py-10 text-center" data-test="onboarding-document-verified">
                <span class="grid size-16 place-items-center rounded-full bg-emerald-50 text-emerald-600 dark:bg-emerald-950/50">
                    <twig:ux:icon name="tabler:shield-check" class="size-9"/>
                </span>
                <div>
                    <p class="font-display text-base font-semibold text-slate-900 dark:text-white">Pièce vérifiée</p>
                    <p class="mt-0.5 text-sm text-slate-500">Document authentifié avec succès.</p>
                </div>
            </div>
        {% elseif analyzing %}
            {# État analyse — rendu serveur ; le timer est tenu par Stimulus. #}
            <div id="onboarding-doc-scanner" data-onboarding-target="scanner" class="flex flex-col items-center gap-4 px-6 py-10 text-center">
                <div class="onboarding-scan relative h-28 w-44 overflow-hidden rounded-lg bg-gradient-to-br from-slate-100 to-slate-200 ring-1 ring-slate-300 dark:from-slate-800 dark:to-slate-700">
                    <span class="absolute left-3 top-3 size-7 rounded-full bg-slate-300 dark:bg-slate-600"></span>
                    <span class="absolute left-12 top-4 h-2 w-24 rounded bg-slate-300 dark:bg-slate-600"></span>
                    <span class="absolute left-12 top-8 h-2 w-16 rounded bg-slate-300 dark:bg-slate-600"></span>
                    <span class="absolute bottom-4 left-3 h-2 w-36 rounded bg-slate-300 dark:bg-slate-600"></span>
                    <span class="onboarding-scan-line absolute inset-x-0 top-0 h-0.5 bg-emerald-400 shadow-[0_0_12px_2px] shadow-emerald-400/60"></span>
                </div>
                <div class="flex items-center gap-2 text-sm font-medium text-slate-600 dark:text-slate-300">
                    <twig:ux:icon name="tabler:loader-2" class="size-4 animate-spin"/>
                    Analyse du document en cours…
                </div>
            </div>

            {# Déclencheur masqué : confirme la pièce une fois le timer écoulé. #}
            <button type="button" class="hidden"
                    data-onboarding-target="confirm"
                    data-action="live#action" data-live-action-param="provideDocument"></button>
        {% else %}
            {# État inactif #}
            <div id="onboarding-doc-idle" class="flex flex-col items-center gap-4 px-6 py-10 text-center">
                <span class="grid size-16 place-items-center rounded-full bg-[#0a2540]/5 text-[#0a2540] dark:bg-white/10 dark:text-white">
                    <twig:ux:icon name="tabler:id" class="size-9"/>
                </span>
                <div>
                    <p class="font-display text-base font-semibold text-slate-900 dark:text-white">Déposez votre pièce d'identité</p>
                    <p class="mt-0.5 text-sm text-slate-500">Recto-verso, lisible et non rogné.</p>
                </div>
                <button type="button"
                        data-action="live#action" data-live-action-param="startAnalysis"
                        data-test="onboarding-deposit"
                        class="flex items-center gap-2 rounded-xl bg-[#0a2540] px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#0a2540]/90 active:scale-[.99] dark:bg-white dark:text-[#0a2540]">
                    <twig:ux:icon name="tabler:camera" class="size-5"/>
                    Déposer ma pièce
                </button>
            </div>
        {% endif %}
    </div>

    {{ form_errors(form.documentProvided) }}

    <p class="flex items-center gap-1.5 text-xs text-slate-400">
        <twig:ux:icon name="tabler:lock" class="size-3.5"/>
        Démonstration : aucun fichier n'est réellement transmis ni stocké.
    </p>
</div>
