<div class="space-y-6">
    <header>
        <h1 class="font-display text-xl font-bold tracking-tight text-slate-900 dark:text-white">Choisissez votre offre</h1>
        <p class="mt-1 text-sm text-slate-500">Sans engagement, modifiable à tout moment.</p>
    </header>

    {# Cartes d'offres — radio #}
    <div class="space-y-3">
        {% for offer in this.offers %}
            {% set selected = form.offer.vars.value == offer.slug %}
            <label class="relative block cursor-pointer">
                <input type="radio" name="{{ form.offer.vars.full_name }}" value="{{ offer.slug }}"
                       {{ selected ? 'checked' }}
                       data-test="offer-{{ offer.slug }}"
                       class="peer sr-only">
                <div class="rounded-2xl border border-slate-200 bg-white p-4 transition peer-checked:border-[#0a2540] peer-checked:ring-2 peer-checked:ring-[#0a2540]/20 dark:border-slate-700 dark:bg-slate-900 dark:peer-checked:border-white">
                    <div class="flex items-start gap-3">
                        <span class="grid size-10 shrink-0 place-items-center rounded-full bg-[#0a2540]/5 text-[#0a2540] dark:bg-white/10 dark:text-white">
                            <twig:ux:icon name="{{ offer.icon }}" class="size-5.5"/>
                        </span>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-baseline justify-between gap-2">
                                <p class="font-display font-semibold text-slate-900 dark:text-white">{{ offer.name }}</p>
                                <p class="shrink-0 font-display text-sm font-semibold text-[#16386b] dark:text-sky-400">
                                    {{ offer.monthlyPriceCents == 0 ? 'Gratuit' : offer.monthlyPriceCents|money ~ ' /mois' }}
                                </p>
                            </div>
                            <p class="mt-0.5 text-xs text-slate-500">{{ offer.tagline }}</p>
                            {% if offer.highlighted %}
                                <span class="mt-2 inline-block rounded-full bg-amber-100 px-2 py-0.5 text-2xs font-semibold uppercase tracking-wide text-amber-700 dark:bg-amber-950/50 dark:text-amber-400">Le plus choisi</span>
                            {% endif %}
                        </div>
                    </div>
                    <ul class="mt-3 space-y-1 border-t border-slate-100 pt-3 dark:border-slate-800">
                        {% for perk in offer.perks %}
                            <li class="flex items-center gap-2 text-xs text-slate-600 dark:text-slate-300">
                                <twig:ux:icon name="tabler:check" class="size-3.5 shrink-0 text-emerald-500"/>
                                {{ perk }}
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </label>
        {% endfor %}
        {{ form_errors(form.offer) }}
    </div>

    {# Récapitulatif #}
    <div class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800" data-test="onboarding-summary">
        <h2 class="mb-3 font-display text-xs font-semibold uppercase tracking-wider text-slate-400">Récapitulatif</h2>
        <dl class="space-y-2 text-sm">
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Titulaire</dt>
                <dd class="text-right font-medium text-slate-900 dark:text-white">
                    {{ form.civility.vars.data ? form.civility.vars.data.short ~ ' ' }}{{ form.firstName.vars.data }} {{ form.lastName.vars.data }}
                </dd>
            </div>
            {% if form.birthDate.vars.data %}
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Né(e) le</dt>
                    <dd class="text-right font-medium text-slate-900 dark:text-white">{{ form.birthDate.vars.data|day_label }}</dd>
                </div>
            {% endif %}
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Contact</dt>
                <dd class="text-right font-medium text-slate-900 dark:text-white">{{ form.email.vars.data }}<br>{{ form.phone.vars.data }}</dd>
            </div>
            <div class="flex justify-between gap-4">
                <dt class="text-slate-500">Adresse</dt>
                <dd class="text-right font-medium text-slate-900 dark:text-white">{{ form.addressLine.vars.data }}<br>{{ form.postalCode.vars.data }} {{ form.city.vars.data }}</dd>
            </div>
            {% if this.selectedOffer %}
                <div class="flex justify-between gap-4 border-t border-slate-200 pt-2 dark:border-slate-700">
                    <dt class="text-slate-500">Offre</dt>
                    <dd class="text-right font-semibold text-[#0a2540] dark:text-white">
                        {{ this.selectedOffer.name }}
                        <span class="text-slate-400">· {{ this.selectedOffer.monthlyPriceCents == 0 ? 'Gratuit' : this.selectedOffer.monthlyPriceCents|money ~ ' /mois' }}</span>
                    </dd>
                </div>
            {% endif %}
        </dl>
    </div>

    {# Consentement = « signature » #}
    <div>
        <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-slate-200 bg-white p-4 transition has-[:checked]:border-[#0a2540] dark:border-slate-700 dark:bg-slate-900">
            <input type="checkbox" name="{{ form.consent.vars.full_name }}" id="{{ form.consent.vars.id }}" value="1"
                   {{ form.consent.vars.checked ? 'checked' }}
                   data-test="consent"
                   class="mt-0.5 size-5 shrink-0 rounded border-slate-300 text-[#0a2540] focus:ring-2 focus:ring-[#0a2540]/30 dark:border-slate-600 dark:bg-slate-800">
            <span class="text-sm text-slate-600 dark:text-slate-300">
                Je certifie l'exactitude des informations fournies et j'accepte les
                <span class="font-medium text-[#16386b] dark:text-sky-400">conditions générales</span> d'ouverture de compte.
            </span>
        </label>
        {{ form_errors(form.consent) }}
    </div>
</div>
