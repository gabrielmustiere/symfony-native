{% extends 'bank/base.html.twig' %}

{% block title %}WebAuthn · Nevertime Solutions{% endblock %}

{% block body %}
    {# Hero #}
    <header class="bg-gradient-to-br from-[#0a2540] to-[#16386b] pb-8 pt-[calc(1.5rem+env(safe-area-inset-top))] text-white">
      <div class="mx-auto max-w-2xl px-5">
        <div class="flex items-center gap-3">
            <span class="grid size-10 place-items-center rounded-full bg-white/15">
                <twig:ux:icon name="tabler:fingerprint" class="size-5.5"/>
            </span>
            <div>
                <h1 class="font-display text-xl font-bold tracking-tight">Démo WebAuthn</h1>
                <p class="text-xs text-white/60">Face ID · Touch ID · passkey</p>
            </div>
        </div>
        <p class="mt-4 text-sm text-white/70">
            Déclenche l'invite système pour tester le comportement dans Hotwire Native.
            Simulation 100 % client — aucun challenge n'est vérifié côté serveur.
        </p>
      </div>
    </header>

    <div data-controller="webauthn" class="mx-auto max-w-2xl space-y-5 px-4 pt-6">

        {# Actions #}
        <section class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800">
            <h2 class="font-display text-sm font-semibold uppercase tracking-wider text-slate-400">Actions</h2>
            <p class="mt-1 mb-4 text-sm text-slate-500">Créez d'abord un passkey, puis testez l'authentification.</p>

            <div class="space-y-3">
                <button type="button" data-action="webauthn#register"
                        class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-[#0a2540] px-4 py-3 text-sm font-semibold text-white transition hover:bg-[#16386b] active:scale-[.99]">
                    <twig:ux:icon name="tabler:fingerprint" class="size-5"/>
                    Créer un passkey
                </button>

                <button type="button" data-action="webauthn#authenticate" data-webauthn-target="authButton" disabled
                        class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-white px-4 py-3 text-sm font-semibold text-[#0a2540] ring-1 ring-slate-200 transition hover:bg-slate-50 active:scale-[.99] disabled:cursor-not-allowed disabled:opacity-40 dark:bg-slate-900 dark:text-white dark:ring-slate-700">
                    <twig:ux:icon name="tabler:lock-open" class="size-5"/>
                    S'authentifier
                </button>
            </div>
        </section>

        {# Support #}
        <section class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800">
            <div class="mb-2 flex items-center gap-2">
                <twig:ux:icon name="tabler:device-mobile-check" class="size-5 text-slate-400"/>
                <h2 class="font-display text-sm font-semibold uppercase tracking-wider text-slate-400">Support</h2>
            </div>
            <p data-webauthn-target="support" data-state="pending"
               class="text-sm text-slate-500 data-[state=ok]:text-emerald-600 data-[state=warn]:text-amber-600 data-[state=ko]:text-rose-600 dark:data-[state=ok]:text-emerald-400 dark:data-[state=warn]:text-amber-400 dark:data-[state=ko]:text-rose-400">
                Détection en cours…
            </p>
        </section>

        {# Statut #}
        <section class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800">
            <h2 class="mb-3 font-display text-sm font-semibold uppercase tracking-wider text-slate-400">Statut</h2>
            <div class="flex items-start gap-3 rounded-xl bg-slate-50 p-4 dark:bg-slate-800/60">
                <twig:ux:icon name="tabler:info-circle" class="mt-0.5 size-5 shrink-0 text-slate-400"/>
                <p data-webauthn-target="status" data-state="idle"
                   class="text-sm text-slate-700 data-[state=ok]:text-emerald-600 data-[state=pending]:text-[#16386b] data-[state=ko]:text-rose-600 dark:text-slate-300 dark:data-[state=ok]:text-emerald-400 dark:data-[state=pending]:text-sky-400 dark:data-[state=ko]:text-rose-400">
                    En attente d'une action.
                </p>
            </div>
        </section>

        {# Réponses brutes #}
        <section class="rounded-2xl border border-slate-800 bg-slate-900 p-5">
            <div class="mb-3 flex items-center gap-2">
                <twig:ux:icon name="tabler:terminal-2" class="size-5 text-sky-400"/>
                <h2 class="font-display text-sm font-semibold uppercase tracking-wider text-white">Réponses brutes</h2>
            </div>
            <div data-webauthn-target="log" class="max-h-96 overflow-y-auto font-mono text-xs">
                <p class="text-slate-500">Les réponses de l'authentificateur s'afficheront ici.</p>
            </div>
        </section>

    </div>
{% endblock %}
