{% extends 'base.html.twig' %}

{% block title %}WebAuthn · Symfony Template{% endblock %}

{% block body %}
    {# Header #}
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="font-display text-2xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-3xl">
                Démo WebAuthn
            </h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                Déclenche l'invite système (Face ID / Touch ID / passkey) pour tester le comportement dans Hotwire Native.
                Simulation 100 % client — aucun challenge n'est vérifié côté serveur.
            </p>
        </div>
    </div>

    <div data-controller="webauthn" class="grid grid-cols-1 gap-6 lg:grid-cols-3">

        {# Actions #}
        <div class="space-y-6 lg:col-span-1">
            <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
                <h2 class="mb-1 font-display text-lg font-semibold text-gray-900 dark:text-white">Actions</h2>
                <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">
                    Créez d'abord un passkey, puis testez l'authentification.
                </p>

                <div class="space-y-3">
                    <twig:Button variant="brand" data-action="webauthn#register" class="w-full">
                        <twig:ux:icon name="tabler:fingerprint" class="size-4 me-1.5"/>
                        Créer un passkey
                    </twig:Button>

                    <twig:Button variant="outline" data-action="webauthn#authenticate" data-webauthn-target="authButton" disabled class="w-full">
                        <twig:ux:icon name="tabler:lock-open" class="size-4 me-1.5"/>
                        S'authentifier
                    </twig:Button>
                </div>
            </div>

            {# Support #}
            <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
                <div class="mb-2 flex items-center gap-2">
                    <twig:ux:icon name="tabler:device-mobile-check" class="size-5 text-gray-500 dark:text-gray-400"/>
                    <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-gray-700 dark:text-gray-300">Support</h3>
                </div>
                <p data-webauthn-target="support" data-state="pending"
                   class="text-sm text-gray-500 data-[state=ok]:text-emerald-600 data-[state=warn]:text-amber-600 data-[state=ko]:text-rose-600 dark:text-gray-400 dark:data-[state=ok]:text-emerald-400 dark:data-[state=warn]:text-amber-400 dark:data-[state=ko]:text-rose-400">
                    Détection en cours…
                </p>
            </div>
        </div>

        {# Statut + log #}
        <div class="space-y-6 lg:col-span-2">
            <div class="rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
                <h2 class="mb-3 font-display text-lg font-semibold text-gray-900 dark:text-white">Statut</h2>
                <div class="flex items-start gap-3 rounded-md bg-gray-50 p-4 dark:bg-gray-700/40">
                    <twig:ux:icon name="tabler:info-circle" class="mt-0.5 size-5 shrink-0 text-gray-400"/>
                    <p data-webauthn-target="status" data-state="idle"
                       class="text-sm text-gray-700 data-[state=ok]:text-emerald-600 data-[state=pending]:text-violet-600 data-[state=ko]:text-rose-600 dark:text-gray-300 dark:data-[state=ok]:text-emerald-400 dark:data-[state=pending]:text-violet-400 dark:data-[state=ko]:text-rose-400">
                        En attente d'une action.
                    </p>
                </div>
            </div>

            <div class="rounded-lg border border-gray-700 bg-gray-900 p-6">
                <div class="mb-3 flex items-center gap-2">
                    <twig:ux:icon name="tabler:terminal-2" class="size-5 text-violet-400"/>
                    <h2 class="font-display text-sm font-semibold uppercase tracking-wider text-white">Réponses brutes</h2>
                </div>
                <div data-webauthn-target="log" class="max-h-96 overflow-y-auto font-mono text-xs">
                    <p class="text-gray-500">Les réponses de l'authentificateur s'afficheront ici.</p>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
