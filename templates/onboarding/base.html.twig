<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#0a2540">
    <title>{% block title %}Ouvrir un compte · Nevertime Solutions{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=PT+Mono&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2224%22 fill=%22%230a2540%22/><text y=%221.05em%22 x=%220.5em%22 text-anchor=%22middle%22 font-family=%22sans-serif%22 font-size=%2272%22 font-weight=%22700%22 fill=%22%23ffffff%22>N</text></svg>">
    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="min-h-full bg-slate-50 font-body text-slate-800 antialiased dark:bg-slate-950 dark:text-slate-200">

{# En-tête sobre dédié au parcours : marque + sortie, sans navigation bancaire. #}
<header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/90 backdrop-blur pt-[env(safe-area-inset-top)] dark:border-slate-800 dark:bg-slate-950/90">
    <div class="mx-auto flex max-w-2xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-2">
            <span class="grid size-7 place-items-center rounded-md bg-[#0a2540] text-sm font-bold text-white">N</span>
            <span class="font-display text-sm font-semibold tracking-tight text-slate-900 dark:text-white">Nevertime Solutions</span>
        </div>
        <a href="{{ path('app_bank_home') }}"
           class="grid size-9 place-items-center rounded-full text-slate-400 transition hover:bg-slate-100 hover:text-slate-600 dark:hover:bg-slate-800"
           aria-label="Quitter le parcours"
           data-test="onboarding-quit">
            <twig:ux:icon name="tabler:x" class="size-5"/>
        </a>
    </div>
</header>

<main class="mx-auto max-w-2xl px-4 pb-[calc(1.5rem+env(safe-area-inset-bottom))] pt-4">
    {% block body %}{% endblock %}
</main>

</body>
</html>
