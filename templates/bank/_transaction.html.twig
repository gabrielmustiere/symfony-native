<div class="flex items-center gap-3 px-4 py-3 {{ divider|default(false) ? 'border-b border-slate-100 dark:border-slate-800' }}">
    <span class="grid size-10 shrink-0 place-items-center rounded-full bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-300">
        <twig:ux:icon name="{{ tx.category.icon }}" class="size-5"/>
    </span>
    <span class="min-w-0 flex-1">
        <span class="block truncate font-medium text-slate-900 dark:text-white">{{ tx.label }}</span>
        <span class="block text-xs text-slate-400">{{ tx.category.label }}</span>
    </span>
    <span class="font-display font-semibold tabular-nums {{ tx.isCredit ? 'text-emerald-600 dark:text-emerald-400' : 'text-slate-900 dark:text-white' }}">
        {{ tx.amountCents|money(true) }}
    </span>
</div>
