{% extends 'bank/base.html.twig' %}

{% block title %}Profil · Nevertime Solutions{% endblock %}

{% block body %}
    {# Hero profil #}
    <header class="bg-gradient-to-br from-[#0a2540] to-[#16386b] pb-8 pt-[calc(1.5rem+env(safe-area-inset-top))] text-center text-white">
      <div class="mx-auto max-w-2xl px-5">
        <span class="mx-auto grid size-20 place-items-center rounded-full bg-white/15 font-display text-2xl font-semibold">
            {{ customer.initials }}
        </span>
        <p class="mt-3 font-display text-xl font-bold">{{ customer.fullName }}</p>
        <p class="text-sm text-white/60">Client {{ customer.customerNumber }}</p>
        <p class="mt-1 text-xs text-white/50">Membre depuis {{ customer.memberSince|day_label }}</p>
      </div>
    </header>

    <div class="mx-auto max-w-2xl">

    {% set sections = [
        {
            title: 'Mon compte',
            rows: [
                { label: 'Données personnelles', value: customer.email, icon: 'tabler:user-circle' },
                { label: 'Téléphone', value: customer.phone, icon: 'tabler:phone' },
                { label: 'Documents & RIB', value: null, icon: 'tabler:file-text' }
            ]
        },
        {
            title: 'Sécurité',
            rows: [
                { label: 'Code secret & Face ID', value: 'Activé', icon: 'tabler:fingerprint' },
                { label: 'Appareils de confiance', value: 'iPhone de Camille', icon: 'tabler:device-mobile' }
            ]
        },
        {
            title: 'Préférences',
            rows: [
                { label: 'Notifications', value: null, icon: 'tabler:bell' },
                { label: 'Aide & contact', value: null, icon: 'tabler:lifebuoy' }
            ]
        }
    ] %}

    {% for section in sections %}
        <section class="px-5 pt-6">
            <h2 class="mb-2 px-1 font-display text-xs font-semibold uppercase tracking-wider text-slate-400">{{ section.title }}</h2>
            <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800">
                {% for row in section.rows %}
                    <div class="flex items-center gap-3 px-4 py-3.5 {{ not loop.last ? 'border-b border-slate-100 dark:border-slate-800' }}">
                        <span class="grid size-9 shrink-0 place-items-center rounded-full bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-300">
                            <twig:ux:icon name="{{ row.icon }}" class="size-5"/>
                        </span>
                        <span class="min-w-0 flex-1">
                            <span class="block text-sm font-medium text-slate-700 dark:text-slate-200">{{ row.label }}</span>
                            {% if row.value %}<span class="block truncate text-xs text-slate-400">{{ row.value }}</span>{% endif %}
                        </span>
                        <twig:ux:icon name="tabler:chevron-right" class="size-4 shrink-0 text-slate-300"/>
                    </div>
                {% endfor %}
            </div>
        </section>
    {% endfor %}

    {# Déconnexion #}
    <section class="px-5 pt-6">
        <a href="{{ path('app_logout') }}"
           class="flex items-center justify-center gap-2 rounded-2xl bg-white px-4 py-3.5 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-slate-100 dark:bg-slate-900 dark:ring-slate-800">
            <twig:ux:icon name="tabler:logout" class="size-5"/>
            Se déconnecter
        </a>
    </section>

    <p class="px-5 pt-6 text-center text-xs text-slate-400">
        Nevertime Solutions · version 2.4.1
    </p>
    </div>
{% endblock %}
