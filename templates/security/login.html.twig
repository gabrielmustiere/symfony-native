{% extends 'security.html.twig' %}

{% block title %}Connexion · Nevertime Solutions{% endblock %}

{% block body %}
    <div class="grid min-h-screen grid-cols-1 lg:grid-cols-2">

        {# Form column #}
        <div class="flex flex-col justify-between px-6 py-10 sm:px-12 lg:px-16">

            <div class="flex items-center gap-2.5">
                <span class="grid size-9 place-items-center rounded-lg bg-[#0a2540] font-display text-sm font-bold text-white">N</span>
                <div class="leading-tight">
                    <div class="font-display text-base font-semibold tracking-tight text-slate-900 dark:text-white">Nevertime Solutions</div>
                    <div class="text-2xs uppercase tracking-wider text-slate-400">Espace client</div>
                </div>
            </div>

            <div class="mx-auto w-full max-w-sm">
                <h1 class="font-display text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Bon retour</h1>
                <p class="mt-2 text-sm text-slate-500">
                    Connectez-vous pour accéder à vos comptes.
                </p>

                <form method="post" class="mt-8 space-y-5">
                    {% if error %}
                        <div role="alert" class="flex items-start gap-3 rounded-xl border border-rose-200 bg-rose-50 p-3 dark:border-rose-900/50 dark:bg-rose-900/30">
                            <twig:ux:icon name="tabler:alert-circle" class="mt-0.5 size-5 shrink-0 text-rose-600 dark:text-rose-400"/>
                            <div class="text-sm text-rose-800 dark:text-rose-200">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        </div>
                    {% endif %}

                    {% if app.user %}
                        <div class="flex items-start gap-3 rounded-xl border border-sky-200 bg-sky-50 p-3 dark:border-sky-500/40 dark:bg-sky-500/10">
                            <twig:ux:icon name="tabler:user-check" class="mt-0.5 size-5 shrink-0 text-sky-700 dark:text-sky-300"/>
                            <div class="text-sm text-sky-900 dark:text-sky-200">
                                Connecté en tant que <span class="font-medium">{{ app.user.userIdentifier }}</span>.
                                <a href="{{ logout_path() }}" class="ml-1 font-medium underline hover:no-underline">Se déconnecter</a>
                            </div>
                        </div>
                    {% endif %}

                    <div>
                        <label for="username" class="mb-1.5 block text-sm font-medium text-slate-900 dark:text-slate-100">Identifiant</label>
                        <input id="username" type="email" name="_username" value="{{ last_username }}"
                               required autocomplete="email" autofocus
                               placeholder="vous@exemple.com"
                               class="block w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-[#16386b] focus:ring-2 focus:ring-[#16386b]/20 focus:outline-none dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:placeholder:text-slate-500"/>
                    </div>

                    <div>
                        <label for="password" class="mb-1.5 block text-sm font-medium text-slate-900 dark:text-slate-100">Mot de passe</label>
                        <input id="password" type="password" name="_password" required
                               autocomplete="current-password"
                               placeholder="••••••••"
                               class="block w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-[#16386b] focus:ring-2 focus:ring-[#16386b]/20 focus:outline-none dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:placeholder:text-slate-500"/>
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                           value="{{ csrf_token('authenticate') }}">

                    <div class="flex items-center justify-between">
                        <label class="inline-flex items-center gap-2 text-sm text-slate-600 dark:text-slate-300">
                            <input id="_remember_me" type="checkbox" name="_remember_me"
                                   class="size-4 rounded border-slate-300 text-[#0a2540] focus:ring-2 focus:ring-[#16386b]/20 dark:border-slate-700 dark:bg-slate-900"/>
                            Rester connecté
                        </label>
                        <a href="#" class="text-sm font-medium text-[#16386b] hover:underline dark:text-sky-400">Mot de passe oublié ?</a>
                    </div>

                    <button type="submit"
                            class="flex w-full items-center justify-center gap-2 rounded-xl bg-[#0a2540] px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-[#16386b] focus:outline-none focus:ring-2 focus:ring-[#16386b] focus:ring-offset-2">
                        Se connecter
                        <twig:ux:icon name="tabler:arrow-right" class="size-4"/>
                    </button>
                </form>

                <p class="mt-8 text-center text-xs text-slate-500">
                    Identifiants de démo : <span class="font-mono text-slate-700 dark:text-slate-300">admin@example.com</span> / <span class="font-mono text-slate-700 dark:text-slate-300">password</span>
                </p>
            </div>

            <p class="text-center text-xs text-slate-400">© {{ "now"|date("Y") }} Nevertime Solutions — Espace client.</p>
        </div>

        {# Decorative column #}
        <div class="relative hidden overflow-hidden bg-gradient-to-br from-[#0a2540] to-[#16386b] lg:block">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(255,255,255,0.10),transparent_55%)]"></div>

            <div class="relative flex h-full flex-col justify-between p-12 text-white">
                <div class="flex items-center gap-2 font-mono text-xs uppercase tracking-[0.2em] text-white/60">
                    <twig:ux:icon name="tabler:shield-lock" class="size-4"/>
                    Connexion sécurisée
                </div>

                <div class="max-w-md">
                    <h2 class="font-display text-4xl font-bold leading-tight tracking-tight">
                        Votre banque,<br/>
                        <span class="text-sky-300">en toute confiance.</span>
                    </h2>
                    <p class="mt-4 text-sm text-white/70">
                        Vos comptes, vos cartes et vos opérations réunis dans une application sobre, claire et sécurisée.
                    </p>
                </div>

                <div class="flex items-center gap-3 text-xs text-white/60">
                    <twig:ux:icon name="tabler:lock" class="size-4"/>
                    <span>Chiffrement de bout en bout · Authentification biométrique</span>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
